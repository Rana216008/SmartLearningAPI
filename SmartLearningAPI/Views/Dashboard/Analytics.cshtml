@model AnalyticsViewModel
@{
    Layout = null;
    // Helper function for category colors
    string GetCategoryColor(string category) => category switch
    {
        "Arabic" => "#4CAF50",
        "English" => "#2196F3",
        "Colors" => "#FF9800",
        _ => "#9E9E9E"
    };
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تحليل الأداء</title>
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>

  html, body {
    margin: 0;
    padding: 0;
    overflow-y: auto !important;
    height: auto !important;
}

body {
    position: relative;
    min-height: 100vh;
    background: url('/imge/Rash_and_kid.png') no-repeat center center fixed;
    background-size: cover;
    font-family: 'Segoe UI', sans-serif;
}

/* Light overlay – now clearer */
body::before {
    content: "";
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.25);   /* was 0.5, now lighter */
    backdrop-filter: none;              /* no blur, image stays sharp */
    z-index: -1;
}

/* Content panels above overlay */
.dashboard-container,
.main-glass-panel {
    position: relative;
    z-index: 1;
    overflow: visible !important;
    height: auto !important;
    max-height: none !important;        /* moved max-height here */
}

/* ===== All other styles unchanged ===== */
.analytics-container {
    padding: 2rem;
}
.master-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
}
.master-card {
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(0,247,255,0.15);
    border-radius: 20px;
    padding: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    transition: 0.3s;
    position: relative;
}
.master-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 0 20px rgba(0,247,255,0.2);
}
.master-ring {
    position: relative;
    width: 80px;
    height: 80px;
}
.ring-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-weight: bold;
    color: #00f7ff;
    font-size: 1.2rem;
}
.master-info {
    flex: 1;
    min-width: 150px;
}
.master-info h4 {
    margin: 0 0 5px 0;
    font-size: 1.4rem;
}
.cat-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    color: #fff;
    margin: 5px 0;
}
.audio-trigger {
    cursor: pointer;
    color: #00f7ff;
    margin-top: 5px;
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.9rem;
}
.master-status {
    position: absolute;
    bottom: 10px;
    left: 15px;
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.9rem;
}
.detail-link {
    position: absolute;
    bottom: 10px;
    right: 15px;
    background: #00f7ff;
    color: #000;
    text-decoration: none;
    border: none;
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: bold;
    transition: 0.3s;
}
.detail-link:hover {
    background: #00d2ff;
    color: #000;
}
.empty-state {
    text-align: center;
    opacity: 0.7;
    font-size: 1.1rem;
}
.category-stats {
    display: flex;
    gap: 2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
}
.stat-box {
    flex: 1;
    min-width: 120px;
    background: rgba(0,0,0,0.3);
    border-radius: 16px;
    padding: 1rem;
    text-align: center;
}
.section-box {
    background: linear-gradient(145deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
    border-radius: 20px;
    padding: 1.5rem;
    border: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 1.5rem;
}
.section-box h3 {
    margin-top: 0;
    border-left: 4px solid #00f7ff;
    padding-left: 10px;
    color: #e2e8f0;
}
    </style>
</head>
<body>

<div class="dashboard-container">
    <div class="main-glass-panel">
        <div class="panel-header">
            <div class="header-main">
                <h2>📊 تحليل أداء الطفل</h2>
            </div>
            <p class="brand-text">• تفاصيل ما تعلمه الطفل •</p>
        </div>

        <!-- Quick stats -->
        <div class="category-stats">
            <div class="stat-box">
                <h4>@Model.TotalScans</h4>
                <p>إجمالي المحاولات</p>
            </div>
            <div class="stat-box">
                <h4>@Model.TotalLearned</h4>
                <p>تم إتقانها</p>
            </div>
          
        </div>

        <!-- Category breakdown -->
        <div class="section-box">
            <h3>التصنيفات</h3>
            <div class="category-stats">
                    @foreach (var cat in Model.CategoryCounts)
                    {
                        <div class="stat-box">
                            <h5>@cat.Key</h5>
                            <span>@cat.Value كروت</span>
                        </div>
                    }
            </div>
        </div>

        <!-- Master card grid -->
        <div class="section-box">
            <h3>📚 الكروت التي تم التفاعل معها</h3>
            <div class="master-grid">
                    @foreach (var item in Model.LearnedItems)
                    {
                        // Calculate dashoffset for 3-scan mastery (circumference 220)
                        double progressPercent = Math.Min(item.ScanCount, 3) / 3.0; // max 1.0
                        double dashoffset = 220 - (220 * progressPercent);

                        <div class="master-card">
                            <div class="master-ring">
                                <svg width="80" height="80">
                                    <circle cx="40" cy="40" r="35" stroke="#ffffff20" stroke-width="6" fill="none" />
                                    <circle cx="40" cy="40" r="35" stroke="#00f7ff" stroke-width="6" fill="none"
                                            stroke-dasharray="220" 
                                            stroke-dashoffset="@dashoffset" 
                                            stroke-linecap="round" transform="rotate(-90 40 40)" />
                                </svg>
                                <span class="ring-text">@item.ScanCount/3</span>
                            </div>

                            <div class="master-info">
                                <h4>@item.CardName</h4>
                                <span class="cat-badge" style="background: @GetCategoryColor(item.Category)">@item.Category</span>
                                <div class="audio-trigger" onclick="playAudio(@item.TrackNumber)">
                                    <i class="fas fa-volume-up"></i> تشغيل الصوت
                                </div>
                            </div>

                            <div class="master-status">
                                @if (item.IsLearned)
                                {
                                        <i class="fas fa-star" style="color:#ffd700;"></i>
                                        <span>مُتقن</span>
                                }
                                else
                                {
                                        <span>يتعلم...</span>
                                }
                            </div>
                       <button class="detail-link" 
            data-name="@item.CardName" 
            data-category="@item.Category" 
            data-uid="@item.UID" 
            data-track="@item.TrackNumber" 
            data-count="@item.ScanCount" 
            data-islearned="@(item.IsLearned ? "true" : "false")">
        <i class="fas fa-arrow-left"></i> تفاصيل
    </button>
                        </div>
                    }
            </div>
                @if (!Model.LearnedItems.Any())
                {
                    <p class="empty-state">لا توجد بيانات حتى الآن. امسح بعض الكروت!</p>
                }
        </div>
      <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 1rem; margin-top: 2rem;">
  <!-- Reset button (red) - opens custom modal -->
<button type="button"
<a href="#" 
   style="display: inline-block; padding: 0.5rem 1.5rem; background: rgba(255, 80, 80, 0.15); border: 1px solid rgba(255, 80, 80, 0.6); border-radius: 14px; color: #ff4d4d; text-decoration: none; font-size: 0.95rem; font-weight: 500; transition: 0.3s;"
   data-reset-url="@Url.Action("ResetProgress", "Dashboard")"
   onclick="event.preventDefault(); showResetModal(this);">
    <i class="fas fa-redo-alt"></i> مسح كل المحاولات
</a>
</button>

    <!-- Back button (blue) -->
    <a href="@Url.Action("Index", "Dashboard")"
       style="display: inline-block; padding: 0.5rem 1.5rem; background: rgba(0, 247, 255, 0.1); border: 1px solid rgba(0, 247, 255, 0.5); border-radius: 14px; color: #00f7ff; text-decoration: none; font-size: 0.95rem; font-weight: 500; transition: 0.3s;">
        <i class="fas fa-arrow-right"></i> العودة للوحة التحكم
    </a>
</div>
    </div>
</div>

<script>
    function playAudio(track) {
        // Attempt to play the audio file from wwwroot/audio/ e.g., 0001.mp3
        var audio = new Audio('/audio/' + track.toString().padStart(4, '0') + '.mp3');
        audio.play().catch(e => console.log('Audio file missing'));
    }
</script>


<!-- Card Detail Modal -->
<div id="cardDetailModal" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.75); backdrop-filter: blur(10px); z-index: 999; justify-content: center; align-items: center;">
    <div class="glass-card" style="max-width: 400px; width: 90%; padding: 2rem; border-radius: 24px; background: rgba(10,12,25,0.9); border: 1px solid rgba(0,247,255,0.25); color: white; position: relative;">
        <span onclick="closeCardDetail()" style="position: absolute; top: 10px; right: 15px; cursor: pointer; font-size: 2rem; color: #00f7ff;">&times;</span>
        <div id="cardDetailContent"></div>
    </div>
</div>

<script>
    // Helper to get category colors (same as Razor version)
    function getCategoryColor(cat) {
        const colors = { 'Arabic': '#4CAF50', 'English': '#2196F3', 'Colors': '#FF9800' };
        return colors[cat] || '#9E9E9E';
    }

    function openCardDetail(name, category, uid, track, scanCount, isLearned) {
        const content = document.getElementById('cardDetailContent');
        const masteryPercent = Math.min(scanCount, 3) * 33.33;
        const learnedText = isLearned ? '✅ متقن' : '🔄 قيد التعلم';
        content.innerHTML = `
            <h2 style="margin:0 0 10px 0; color:#00f7ff;">${name}</h2>
            <span class="cat-badge" style="background:${getCategoryColor(category)}; display:inline-block; padding:4px 14px; border-radius:20px; font-size:0.85rem;">${category}</span>
            <div style="margin-top:20px; display:flex; justify-content:space-between;">
                <div><strong>المسار الصوتي:</strong> ${track}</div>
                <div><strong>المسح:</strong> ${scanCount} مرة</div>
            </div>
            <div style="background:rgba(255,255,255,0.1); border-radius:10px; height:8px; margin:15px 0; overflow:hidden;">
                <div style="width:${masteryPercent}%; height:100%; background:linear-gradient(90deg, #00f7ff, #7c3aed);"></div>
            </div>
            <div style="font-size:1.1rem; margin:10px 0;">${learnedText}</div>
            <div style="font-size:0.85rem; color:#aaa;">UID: ${uid}</div>
            <p style="margin-top:20px; color:#ccc;">📅 سجل التوقيت سيظهر هنا قريباً</p>
        `;
        document.getElementById('cardDetailModal').style.display = 'flex';
    }

    function closeCardDetail() {
        document.getElementById('cardDetailModal').style.display = 'none';
    }

    // Close modal on background click
    document.getElementById('cardDetailModal').addEventListener('click', function(e) {
        if (e.target === this) closeCardDetail();
    });

    // Attach click handlers to all detail buttons (runs on page load)
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.detail-link').forEach(btn => {
            btn.addEventListener('click', function(e) {
                const name = this.dataset.name;
                const category = this.dataset.category;
                const uid = this.dataset.uid;
                const track = parseInt(this.dataset.track);
                const scanCount = parseInt(this.dataset.count);
                const isLearned = this.dataset.islearned === 'true';
                openCardDetail(name, category, uid, track, scanCount, isLearned);
            });
        });
    });
</script>
<!-- Reset Confirmation Modal -->
<div id="resetConfirmModal" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); backdrop-filter: blur(10px); z-index: 9999; justify-content: center; align-items: center;">
    <div class="glass-card" style="max-width: 420px; width: 90%; padding: 2rem; border-radius: 24px; background: rgba(15, 10, 25, 0.95); border: 1px solid rgba(255, 80, 80, 0.5); color: white; text-align: center; position: relative;">
        <div style="font-size: 3rem; margin-bottom: 1rem;">⚠️</div>
        <h3 style="color: #ff4d4d; margin: 0 0 1rem 0;">تحذير ⚠️</h3>
        <p style="font-size: 1.1rem; margin-bottom: 2rem; color: #e2e8f0;">هل أنتي متأكدة من مسح كل محاولات</p>
        <div style="display: flex; justify-content: center; gap: 1rem;">
            <button onclick="closeResetModal()" style="padding: 0.5rem 1.5rem; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.3); border-radius: 12px; color: white; cursor: pointer;">إلغاء</button>
            <button id="confirmResetBtn" style="padding: 0.5rem 1.5rem; background: rgba(255, 80, 80, 0.8); border: none; border-radius: 12px; color: white; cursor: pointer; font-weight: bold;">نعم، امسح الكل</button>
        </div>
    </div>
</div>

<script>
    var resetUrl = '';
    function showResetModal(el) {
        resetUrl = el.getAttribute('data-reset-url');
        document.getElementById('resetConfirmModal').style.display = 'flex';
    }
    function closeResetModal() {
        document.getElementById('resetConfirmModal').style.display = 'none';
    }
    document.getElementById('confirmResetBtn').addEventListener('click', function() {
        window.location.href = resetUrl;
    });
    document.getElementById('resetConfirmModal').addEventListener('click', function(e) {
        if (e.target === this) closeResetModal();
    });
</script>
</body>
</html>