@model DashboardViewModel

<head>
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true" defer></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<div class="dashboard-container">
    <div class="main-glass-panel">

        <div class="panel-header">
            <div class="header-main">
                <span class="user-icon">👩‍🏫</span>
                <h2>لوحة تحكم الأم</h2>
            </div>
            <p class="brand-text">• Smart Learning Platform •</p>
        </div>

        <div class="control-grid">

            <div class="section-box">
                <h3>2. وضع تشغيل الروبوت</h3>
                <div class="button-list">
                    <button class="glass-button @(Model.ActiveMode == "Learning" ? "active" : "")"
                            onclick="updateMode('Status','Learning')">
                        <span class="btn-icon">🎓</span>
                        <div class="btn-text">
                            <span>وضع التعليم</span>
                            <small>Learning Mode</small>
                        </div>
                    </button>

                    <button class="glass-button @(Model.ActiveMode == "Exam" ? "active" : "")"
                            onclick="updateMode('Status','Exam')">
                        <span class="btn-icon">📜</span>
                        <div class="btn-text">
                            <span>وضع الاختبار</span>
                            <small>Exam Mode</small>
                        </div>
                    </button>
                </div>
            </div>

            <div class="section-box">
                <h3>1. نوع المحتوى التعليمي</h3>
                <div class="button-list">
                    <button class="glass-button @(Model.ActiveCategory == "Arabic" ? "active" : "")"
                            onclick="updateMode('Category','Arabic')">
                        <span class="btn-icon">🇸🇦</span>
                        <div class="btn-text">
                            <span>عربي</span>
                            <small>Arabic</small>
                        </div>
                    </button>

                    <button class="glass-button @(Model.ActiveCategory == "English" ? "active" : "")"
                            onclick="updateMode('Category','English')">
                        <span class="btn-icon">🇺🇸</span>
                        <div class="btn-text">
                            <span>إنجليزي</span>
                            <small>English</small>
                        </div>
                    </button>

                    <button class="glass-button @(Model.ActiveCategory == "Colors" ? "active" : "")"
                            onclick="updateMode('Category','Colors')">
                        <span class="btn-icon">🎨</span>
                        <div class="btn-text">
                            <span>ألوان</span>
                            <small>Colors</small>
                        </div>
                    </button>
                </div>
            </div>
        </div>

<div style="text-align: center; margin: 1.2rem 0;">
    <a href="/Dashboard/Analytics" 
       style="display: inline-block; padding: 0.4rem 1.2rem; font-size: 0.9rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.2); border-radius: 10px; color: #e2e8f0; text-decoration: none; font-weight: 500; backdrop-filter: blur(4px); box-shadow: none;">
        <i class="fas fa-chart-line" style="margin-left: 6px;"></i>عرض الأداء
    </a>
</div>

        <div class="bottom-status-bar">
            <span>Robot Connected • النظام متصل بالروبوت</span>
            <i class="fas fa-check-circle status-dot"></i>
        </div>

    </div>




    
