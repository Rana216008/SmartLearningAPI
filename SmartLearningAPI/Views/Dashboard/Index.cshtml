@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="utf-8" />
    <title>Dashboard</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- CSS -->
    <link href="~/css/dashboard.css" rel="stylesheet">

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <h3 class="text-center p-3">📊 لوحة التحكم</h3>

        <a href="#">🏠 الرئيسية</a>
        <a href="#">📚 الحروف</a>
        <a href="#">🐾 الحيوانات</a>
        <a href="#">📈 الإحصائيات</a>
        <a href="/Auth/Logout">🚪 تسجيل خروج</a>
    </div>
    <h2>@Model.LearnedCount</h2>
    <h2>@Model.Attempts</h2>
    <h2>@Model.Errors</h2>
    <!-- Content -->
    <div class="content">

        <!-- Navbar -->
        <nav class="navbar navbar-light bg-light rounded mb-4">
            <span class="navbar-brand mb-0 h5">مرحباً 👋</span>
        </nav>

        <!-- Cards -->
        <div class="row mb-4">

            <div class="col-md-4">
                <div class="card text-white bg-primary p-3">
                    <h5>الحروف المتعلمة</h5>
                    <h2 id="learnedCount">12</h2>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card text-white bg-success p-3">
                    <h5>عدد المحاولات</h5>
                    <h2 id="attempts">45</h2>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card text-white bg-danger p-3">
                    <h5>الأخطاء</h5>
                    <h2 id="errors">8</h2>
                </div>
            </div>

        </div>

        <!-- Charts -->
        <div class="row">

            <div class="col-md-6">
                <div class="card p-3">
                    <h5>📊 تقدم التعلم</h5>
                    <canvas id="progressChart"></canvas>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card p-3">
                    <h5>📈 النتائج</h5>
                    <canvas id="resultChart"></canvas>
                </div>
            </div>

        </div>

    </div>

    <!-- JS -->
    <script src="~/js/dashboard.js"></script>

</body>
</html>