@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" id="html-root">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link rel="stylesheet" href="~/css/Login.css" />
</head>

<body>

    <div class="robot-bg"></div>

    <nav class="navbar">
        <div class="navbar-brand">

            <p class="subtitle">Learning Robot</p>
        </div>

        <div class="language-toggle">
            <button id="lang-btn" class="dropbtn">
                🌐 <span id="lang-label">EN</span>
                <span class="arrow">▼</span>
            </button>

            <div id="lang-dropdown" class="dropdown-content hide">
                <a href="#" data-lang="en">🇺🇸 English</a>
                <a href="#" data-lang="ar">🇸🇦 العربية</a>
            </div>
        </div>
    </nav>

    <div class="login-container">
        <form class="login-form" asp-action="Login" asp-controller="Auth" method="post">

            <h2 id="login-title">RASH</h2>
            <p id="login-subtitle">Login</p>

            <div class="input-group">
                <label id="password-label">Password</label>
                <input type="password" name="password" required />
            </div>

            <button type="submit" id="login-button">Login</button>

            @if (ViewBag.Error != null)
            {
                <p class="error-message">@ViewBag.Error</p>
            }

        </form>
    </div>

    <script src="~/js/Login.js"></script>
</body>
</html>